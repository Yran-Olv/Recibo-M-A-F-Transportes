# =============================================================================
# M.A.F Espelho de Frete — PRODUÇÃO (copie para .env no servidor)
# =============================================================================

NODE_ENV=production

# Porta interna do Node (dentro do container ou processo)
PORT=3000

# Em Docker: 0.0.0.0 | Com systemd (sem Docker): 127.0.0.1
HOST=0.0.0.0

# Porta no SERVIDOR exposta só em localhost (evita conflito com 3000, 8080, etc.)
# Nginx deve fazer proxy_pass para http://127.0.0.1:MAF_HOST_PORT
MAF_HOST_PORT=3010

# Preenchido automaticamente pelo ./install.sh
SESSION_SECRET=

# Senha do admin apenas no primeiro start (se não houver usuário no banco)
ADMIN_INITIAL_PASSWORD=

# -----------------------------------------------------------------------------
# PostgreSQL JÁ INSTALADO NO SERVIDOR (fora do Docker)
# -----------------------------------------------------------------------------
# PostgreSQL no mesmo servidor (install.sh usa 127.0.0.1; Docker sobrescreve no compose)
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=maf_user
# Preenchido pelo install.sh (ou DB_PASS=... ./install.sh)
PGPASSWORD=
PGDATABASE=maf_recibos

# Ou URL única (substitui PGHOST/PGUSER/...)
# DATABASE_URL=postgresql://maf_user:SENHA@127.0.0.1:5432/maf_recibos

# Preenchido pelo install.sh (Nginx + Certbot) — deixe vazio na primeira instalação
DOMAIN=
CERTBOT_EMAIL=
APP_URL=
