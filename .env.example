# Servidor (desenvolvimento)
PORT=3000
NODE_ENV=development
# Produção com Docker: MAF_HOST_PORT=3010 (porta no host para Nginx) — ver .env.production.example

# Obrigatório em produção — use: openssl rand -hex 32
SESSION_SECRET=altere-este-segredo-em-producao

# Senha do usuário admin criado automaticamente no primeiro start (somente se não existir usuário)
ADMIN_INITIAL_PASSWORD=admin123

# PostgreSQL instalado no servidor (não em Docker)
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=maf_user
PGPASSWORD=sua_senha_segura
PGDATABASE=maf_recibos

# Alternativa: URL única
# DATABASE_URL=postgresql://maf_user:sua_senha@127.0.0.1:5432/maf_recibos
